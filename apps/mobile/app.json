{
  "expo": {
    "name": "UrbaEvent",
    "slug": "urbaevent",
    "version": "1.0.40",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "urbaevent",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B365D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.urbacom.urbaevent"
    },
    "android": {
      "versionCode": 35,
      "backgroundColor": "#F8F7F4",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B365D"
      },
      "package": "com.urbacom.urbaevent",
      "permissions": [
        "CAMERA",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "urbaevent",
              "host": "auth-callback"
            },
            {
              "scheme": "urbaevent",
              "host": "reset-password"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1B365D"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "UrbaEvent utilise la caméra pour scanner les badges QR."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "UrbaEvent accède à vos photos pour ajouter des images au catalogue produits."
        }
      ],
      "expo-localization",
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_AFTER_eas_init"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
